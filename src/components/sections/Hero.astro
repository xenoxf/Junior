---
import { info } from '../../lib/info'

const items = [
  'APIs REST', 'Full Stack', 'TypeScript', 'Node.js',
  'React', 'NestJS', 'PostgreSQL', 'Next.js',
  'Tauri', 'Docker', 'Express', 'Prisma',
  'Astro', 'Java', 'Rust', 'Tailwind',
]
---

<section class="hero" id="hero">
  <div class="hero-body">
    <div class="hero-text">
      <div class="hero-badge">
        <span class="badge-dot" />
        Disponible para proyectos
      </div>
      <h1 class="hero-title">
        {info.name}
        <span class="hero-title-sub">{info.title}</span>
      </h1>
      <p class="hero-aliases">
        <span class="alias-label">También conocido como:</span>
        {info.aliases.slice(1, 5).join(' · ')}
      </p>
      <p class="hero-desc">{info.bio}</p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">
          Ver proyectos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={info.cvUrl} class="btn btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          CV
        </a>
      </div>
      <div class="hero-contact-row">
        <a href={info.githubUrl} target="_blank" rel="noopener" class="hero-contact-link" title="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href={info.whatsappUrl} target="_blank" rel="noopener" class="hero-contact-link" title="WhatsApp" style="color: #25d366;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href={`mailto:${info.email}`} class="hero-contact-link" title="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        </a>
        <span class="hero-location">{info.location}</span>
      </div>
    </div>

    <div class="hero-terminal">
      <div class="terminal-bar">
        <span class="terminal-dot red" />
        <span class="terminal-dot amber" />
        <span class="terminal-dot green" />
        <span class="terminal-title">junior.sh</span>
      </div>
      <div class="terminal-body">
        <span class="prompt">$</span>
        <span class="cmd">whoami</span>
        <span class="output">{info.name}</span>
        <br />
        <span class="prompt">$</span>
        <span class="cmd">cat /etc/stack</span>
        <br />
        <span class="output">TypeScript · Node.js · React · NestJS</span>
        <br />
        <span class="output">PostgreSQL · Docker · Tauri · Astro</span>
        <br />
        <span class="prompt">$</span>
        <span class="cmd">curl -s https://api.github.com/xenooxf/repos | jq '. | length'</span>
        <br />
        <span class="output highlight">7+</span>
        <span class="output"> proyectos construidos</span>
        <br />
        <span class="prompt">$</span>
        <span class="blinking-cursor">█</span>
      </div>
    </div>
  </div>

  <div class="hero-marquee">
    <div class="marquee-track">
      {[...items, ...items].map((item) => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 2rem 3rem;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .hero-body {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    animation: fadeInUp 0.7s ease-out;
  }

  .hero-text {
    max-width: 520px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--accent-yellow);
    margin-bottom: 1.5rem;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(234, 179, 8, 0.2);
    background: var(--accent-yellow-glow);
    font-weight: 500;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-yellow);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .hero-title-sub {
    display: block;
    background: linear-gradient(135deg, var(--accent-yellow), var(--accent-amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-weight: 600;
    margin-top: 0.3rem;
    letter-spacing: -0.02em;
  }

  .hero-aliases {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .alias-label {
    color: var(--accent-yellow);
    font-weight: 500;
    margin-right: 0.3rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .hero-contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-contact-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--text-tertiary);
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
  }

  .hero-contact-link:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: var(--bg-secondary);
    transform: translateY(-2px);
  }

  .hero-location {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin-left: 0.5rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--border-color);
  }

  .hero-terminal {
    background: #0f172a;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1e293b;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.amber { background: #f59e0b; }
  .terminal-dot.green { background: #22c55e; }

  .terminal-title {
    margin-left: auto;
    font-size: 0.7rem;
    color: #64748b;
    font-family: var(--font-sans);
  }

  .terminal-body {
    padding: 1rem 1.2rem;
    color: #e2e8f0;
  }

  .prompt { color: #22c55e; margin-right: 0.5rem; }
  .cmd { color: #60a5fa; }
  .output { color: #94a3b8; }
  .output.highlight { color: #38bdf8; font-weight: 700; font-size: 1.1em; }

  .blinking-cursor {
    color: #e2e8f0;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-marquee {
    margin-top: 3rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    overflow: hidden;
    width: 100%;
  }

  .marquee-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .marquee-item {
    font-size: 0.85rem;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    white-space: nowrap;
    font-weight: 500;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .marquee-item:hover {
    border-color: var(--accent-yellow);
    color: var(--accent-yellow);
    background: var(--accent-yellow-glow);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(4px); }
  }

  @media (max-width: 800px) {
    .hero-body {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-terminal { font-size: 0.72rem; }
    .hero-text { max-width: 100%; }
    .hero-contact-row { flex-wrap: wrap; }
  }
</style>
