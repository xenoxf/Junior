---
import { info } from '../../lib/info'

const items = [
  'APIs REST', 'Full Stack', 'TypeScript', 'Node.js',
  'React', 'NestJS', 'PostgreSQL', 'Next.js',
  'Tauri', 'Docker', 'Express', 'Prisma',
  'Astro', 'Java', 'Rust', 'Tailwind',
]
---

<section class="hero" id="hero">
  <div class="hero-body">
    <div class="hero-text">
      <div class="hero-badge">
        <span class="badge-dot" />
        {info.location}
      </div>
      <h1 class="hero-title">
        {info.name}
        <span class="hero-title-sub">{info.title}</span>
      </h1>
      <p class="hero-desc">{info.bio}</p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn-accent">
          Explorar proyectos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={info.cvUrl} class="btn btn-outline">CV</a>
      </div>
    </div>

    <div class="hero-terminal">
      <div class="terminal-bar">
        <span class="terminal-dot red" />
        <span class="terminal-dot amber" />
        <span class="terminal-dot green" />
        <span class="terminal-title">junior.sh</span>
      </div>
      <div class="terminal-body">
        <span class="prompt">$</span>
        <span class="cmd">whoami</span>
        <span class="output">{info.name}</span>
        <br />
        <span class="prompt">$</span>
        <span class="cmd">cat /etc/stack</span>
        <br />
        <span class="output">TypeScript · Node.js · React · NestJS</span>
        <br />
        <span class="output">PostgreSQL · Docker · Tauri · Astro</span>
        <br />
        <span class="prompt">$</span>
        <span class="cmd">curl -s https://api.github.com/xenooxf/repos | jq '. | length'</span>
        <br />
        <span class="output highlight">7+</span>
        <span class="output"> proyectos construidos</span>
        <br />
        <span class="prompt">$</span>
        <span class="blinking-cursor">█</span>
      </div>
    </div>
  </div>

  <div class="hero-marquee">
    <div class="marquee-track">
      {[...items, ...items].map((item) => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 2rem 3rem;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .hero-body {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    animation: fadeInUp 0.7s ease-out;
  }

  .hero-text {
    max-width: 520px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    border: 1px solid var(--border-color);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-green);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .hero-title-sub {
    display: block;
    background: linear-gradient(135deg, var(--accent), var(--accent-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-weight: 600;
    margin-top: 0.3rem;
    letter-spacing: -0.02em;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
  }

  .hero-terminal {
    background: #0f172a;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1e293b;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.amber { background: #f59e0b; }
  .terminal-dot.green { background: #22c55e; }

  .terminal-title {
    margin-left: auto;
    font-size: 0.7rem;
    color: #64748b;
    font-family: var(--font-sans);
  }

  .terminal-body {
    padding: 1rem 1.2rem;
    color: #e2e8f0;
  }

  .prompt { color: #22c55e; margin-right: 0.5rem; }
  .cmd { color: #93c5fd; }
  .output { color: #94a3b8; }
  .output.highlight { color: #38bdf8; font-weight: 700; font-size: 1.1em; }

  .blinking-cursor {
    color: #e2e8f0;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-marquee {
    margin-top: 3rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    overflow: hidden;
    width: 100%;
  }

  .marquee-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .marquee-item {
    font-size: 0.85rem;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    white-space: nowrap;
    font-weight: 500;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .marquee-item:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(37, 99, 235, 0.05);
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(4px); }
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @media (max-width: 800px) {
    .hero-body {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-terminal { font-size: 0.72rem; }
    .hero-text { max-width: 100%; }
  }
</style>
