---
import { info } from '../../lib/info'
---

<section class="section" id="about">
  <div class="about-grid">
    <div class="about-text">
      <div class="section-label">Sobre mí</div>
      <h2 class="section-title">De la curiosidad al <span class="heading-highlight">código</span></h2>
      <p class="about-philosophy">{info.philosophy}</p>

      <div class="about-personal">
        <div class="personal-item">
          <span class="personal-label">Edad</span>
          <span class="personal-value">{info.age} años</span>
        </div>
        <div class="personal-item">
          <span class="personal-label">País</span>
          <span class="personal-value">{info.nationality}</span>
        </div>
        <div class="personal-item">
          <span class="personal-label">También conocido como</span>
          <span class="personal-value">{info.aliases.slice(1).join(', ')}</span>
        </div>
      </div>

      <div class="about-highlight">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <span>100% de mi experiencia productiva en <strong>JS/TS</strong>. Java, Rust y otros son exploración activa.</span>
      </div>

      <div class="about-stats">
        <div class="stat">
          <span class="stat-value">100%</span>
          <span class="stat-label">Productivo en JS/TS</span>
        </div>
        <div class="stat">
          <span class="stat-value">7+</span>
          <span class="stat-label">Proyectos construidos</span>
        </div>
        <div class="stat">
          <span class="stat-value">{info.location.split(',')[0]}</span>
          <span class="stat-label">Ubicación</span>
        </div>
      </div>
    </div>
    <div class="about-visual">
      <div class="tech-orbit">
        <div class="orbit-center">
          <span class="orbit-label">JS/TS</span>
        </div>
        {['React', 'Node.js', 'NestJS', 'Next.js', 'PostgreSQL', 'Docker', 'Astro', 'Tauri', 'Java', 'Rust', 'Express', 'Prisma'].map((tech, i) => {
          const angle = (i / 12) * 360
          const radius = 140
          const x = Math.cos((angle * Math.PI) / 180) * radius
          const y = Math.sin((angle * Math.PI) / 180) * radius
          return (
            <span
              class="orbit-item"
              style={`left: calc(50% + ${x}px); top: calc(50% + ${y}px); animation-delay: ${i * 0.15}s`}
            >
              {tech}
            </span>
          )
        })}
        <div class="orbit-ring ring-1" />
        <div class="orbit-ring ring-2" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-philosophy {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .about-personal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .personal-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.8rem 1rem;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
  }

  .personal-item:last-child {
    grid-column: 1 / -1;
  }

  .personal-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
  }

  .personal-value {
    font-size: 0.9rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .about-highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.2rem;
    border-radius: var(--radius-md);
    background: var(--accent-yellow-glow);
    border: 1px solid rgba(234, 179, 8, 0.15);
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .about-highlight svg {
    color: var(--accent-yellow);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .about-highlight strong {
    color: var(--text-primary);
  }

  .about-stats {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-yellow), var(--accent-amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .about-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .tech-orbit {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .orbit-center {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-yellow), var(--accent-amber));
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 0 40px var(--accent-yellow-glow);
  }

  .orbit-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #0f172a;
    text-align: center;
  }

  .orbit-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    pointer-events: none;
  }

  .ring-1 { width: 240px; height: 240px; }
  .ring-2 { width: 320px; height: 320px; }

  .orbit-item {
    position: absolute;
    font-size: 0.75rem;
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    white-space: nowrap;
    animation: float 3s ease-in-out infinite;
    z-index: 1;
    transform: translate(-50%, -50%);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-fast);
  }

  .orbit-item:hover {
    border-color: var(--accent-yellow);
    color: var(--accent-yellow);
    background: var(--accent-yellow-glow);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-visual { display: none; }
  }
</style>
