---
import { projects } from '../../lib/projects'
import { info } from '../../lib/info'

const categories = [
  { id: 'all', label: 'Todos' },
  { id: 'fullstack', label: 'Full Stack' },
  { id: 'backend', label: 'Backend' },
  { id: 'frontend', label: 'Frontend' },
  { id: 'desktop', label: 'Desktop' },
  { id: 'cli', label: 'CLI' },
]
---

<section class="section" id="projects">
  <div class="projects-header">
    <div class="section-label">Proyectos</div>
    <h2 class="section-title">Lo que <span class="heading-highlight">he construido</span></h2>
    <p class="section-subtitle">
      <span class="accent-yellow">Activos</span> los mantengo y agrego features.
      <span class="muted">Archivados</span> están terminados.
      <span class="muted">— {info.name}</span>
    </p>
  </div>

  <div class="projects-filters" id="project-filters">
    {categories.map((cat) => (
      <button
        class={`filter-pill ${cat.id === 'all' ? 'filter-pill-active' : ''}`}
        data-filter={cat.id}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <div class="projects-grid" id="projects-grid">
    {projects.map((p) => {
      const isActive = p.maintenance === 'active'
      const isArchived = p.maintenance === 'archived'
      return (
        <article class={`project-card ${!p.isMainTech ? 'learning' : ''}`} data-category={p.category}>
          <div class="card-accent" />
          {p.image && (
            <a href={`/projects/${p.id}`} class="card-image-wrap">
              <img src={p.image} alt={p.name} class="card-image" loading="lazy" />
            </a>
          )}
          <div class="card-body">
          <div class="card-header">
            <div class="card-badges">
              <span class={`badge badge-${isActive ? 'active' : isArchived ? 'archived' : 'stable'}`}>
                {isActive ? '▸ Activo' : isArchived ? '■ Archivado' : '● Estable'}
              </span>
              {!p.isMainTech && <span class="badge badge-explore">Explorando</span>}
            </div>
            <span class="card-year">{p.year}</span>
          </div>

          <h3 class="card-title">{p.name}</h3>
          <p class="card-sub">{p.description}</p>

          <div class="card-tags">
            {p.tags.map((t) => <span class="tag">{t}</span>)}
          </div>

          <p class="card-desc">{p.longDescription}</p>

          {p.subProjects && p.subProjects.length > 0 && (
            <div class="card-subs">
              <span class="subs-label">Componentes</span>
              {p.subProjects.map((sp) => (
                <a href={sp.url} target="_blank" rel="noopener" class="sub-link">
                  <div class="sub-body">
                    <span class="sub-name">{sp.name}</span>
                    <span class="sub-tech">{sp.tech}</span>
                  </div>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              ))}
            </div>
          )}

          <div class="card-tech">
            {p.tech.slice(0, 6).map((t) => <span class="chip">{t}</span>)}
            {p.tech.length > 6 && <span class="chip chip-more">+{p.tech.length - 6}</span>}
          </div>

          <div class="card-footer">
            <a href={`/projects/${p.id}`} class="foot-link details">
              Ver detalles
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            {p.demoUrl && (
              <a href={p.demoUrl} target="_blank" rel="noopener" class="foot-link demo">
                {p.category === 'fullstack' ? 'Frontend' : 'Demo'}
              </a>
            )}
            {p.backendUrl && (
              <a href={p.backendUrl} target="_blank" rel="noopener" class="foot-link api">
                API
              </a>
            )}
            {p.githubUrl && (
              <a href={p.githubUrl} target="_blank" rel="noopener" class="foot-link gh">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
              </a>
            )}
          </div>
          </div>
        </article>
      )
    })}
  </div>
</section>

<script>
  const container = document.getElementById('project-filters')
  const grid = document.getElementById('projects-grid')

  if (container && grid) {
    const buttons = container.querySelectorAll('.filter-pill')
    const cards = grid.querySelectorAll('.project-card')

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('filter-pill-active'))
        btn.classList.add('filter-pill-active')
        const filter = btn.dataset.filter

        cards.forEach((card) => {
          if (filter === 'all' || card.dataset.category === filter) {
            card.style.display = ''
            card.style.animation = 'fadeIn 0.3s ease-out'
          } else {
            card.style.display = 'none'
          }
        })
      })
    })
  }
</script>

<style>
  .projects-header { margin-bottom: 2rem; }

  .accent-yellow { color: var(--accent-yellow); font-weight: 600; }
  .muted { color: var(--text-tertiary); font-weight: 500; }

  .projects-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-pill {
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  .filter-pill:hover {
    border-color: var(--accent-yellow);
    color: var(--accent-yellow);
  }

  .filter-pill-active {
    background: var(--accent-yellow-glow);
    border-color: var(--accent-yellow);
    color: var(--accent-yellow);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    position: relative;
    display: flex;
    height: fit-content;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    box-shadow: var(--shadow-sm);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-image-wrap {
    display: block;
    overflow: hidden;
    line-height: 0;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    object-position: top;
    transition: transform var(--transition-slow);
  }

  .card-image-wrap + .card-body {
    padding-top: 0;
  }

  .project-card:hover .card-image {
    transform: scale(1.03);
  }

  .project-card:hover {
    border-color: var(--accent-yellow);
    box-shadow: 0 0 0 1px rgba(234, 179, 8, 0.08), var(--shadow-md);
    transform: translateY(-4px);
  }

  .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-yellow), var(--accent-amber));
    opacity: 0;
    transition: opacity var(--transition-normal);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .project-card:hover .card-accent { opacity: 1; }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .card-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .badge-active {
    background: rgba(5, 150, 105, 0.08);
    color: var(--accent-green);
    border: 1px solid rgba(5, 150, 105, 0.15);
  }

  .badge-archived {
    background: rgba(100, 116, 139, 0.08);
    color: var(--text-tertiary);
    border: 1px solid rgba(100, 116, 139, 0.15);
  }

  .badge-stable {
    background: rgba(37, 99, 235, 0.08);
    color: var(--accent-blue);
    border: 1px solid rgba(37, 99, 235, 0.15);
  }

  .badge-explore {
    background: rgba(124, 58, 237, 0.08);
    color: var(--accent-purple);
    border: 1px solid rgba(124, 58, 237, 0.15);
  }

  .card-year {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    font-weight: 600;
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    color: var(--text-primary);
  }

  .card-sub {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
  }

  .card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 0.8rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    background: var(--bg-tertiary);
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-subs {
    margin-bottom: 1rem;
    padding: 0.7rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }

  .subs-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-tertiary);
    font-weight: 600;
    display: block;
    margin-bottom: 0.4rem;
  }

  .sub-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition-fast);
    gap: 0.5rem;
  }

  .sub-link:hover { background: var(--bg-card); }

  .sub-link + .sub-link {
    border-top: 1px solid var(--border-color);
    margin-top: 0.25rem;
    padding-top: 0.4rem;
  }

  .sub-body {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
  }

  .sub-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent-blue);
  }

  .sub-tech {
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }

  .sub-link svg {
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .sub-link:hover svg {
    transform: translate(2px, -2px);
    color: var(--accent-blue);
  }

  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .chip {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    background: rgba(37, 99, 235, 0.06);
    border: 1px solid rgba(37, 99, 235, 0.1);
    color: var(--accent-blue);
    font-weight: 500;
  }

  .chip-more {
    background: transparent;
    border-style: dashed;
    color: var(--text-tertiary);
  }

  .card-footer {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border-color);
    margin-top: auto;
  }

  .foot-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .foot-link.details {
    background: rgba(234, 179, 8, 0.08);
    color: var(--accent-yellow-dark);
    border: 1px solid rgba(234, 179, 8, 0.15);
  }
  .foot-link.details:hover {
    background: var(--accent-yellow-glow);
    border-color: var(--accent-yellow);
    transform: translateY(-1px);
  }

  .foot-link.demo {
    background: var(--accent-blue);
    color: white;
  }
  .foot-link.demo:hover { background: var(--accent-blue-dark); transform: translateY(-1px); }

  .foot-link.api {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }
  .foot-link.api:hover { background: var(--border-color); }

  .foot-link.gh {
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }
  .foot-link.gh:hover { border-color: var(--accent-yellow); color: var(--accent-yellow); }

  .project-card.learning .card-accent {
    background: linear-gradient(90deg, var(--accent-purple), var(--accent-amber));
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
