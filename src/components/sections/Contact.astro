---
import { info } from '../../lib/info'
---

<section class="section" id="contact">
  <div class="contact-inner">
    <div class="contact-header">
      <div class="section-label">Contacto</div>
      <h2 class="section-title">Construyamos <span class="heading-yellow">algo grande</span> juntos</h2>
      <p class="section-subtitle">
        ¿Tienes un proyecto en mente? ¿Una idea que quieras hacer realidad? Hablemos.
      </p>
    </div>

    <div class="contact-channels">
      <a href={info.githubUrl} target="_blank" rel="noopener" class="channel-card">
        <div class="channel-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </div>
        <div class="channel-info">
          <span class="channel-label">GitHub</span>
          <span class="channel-handle">@xenooxf</span>
        </div>
        <span class="channel-arrow">→</span>
      </a>

      <a href={info.whatsappUrl} target="_blank" rel="noopener" class="channel-card">
        <div class="channel-icon wa">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
        <div class="channel-info">
          <span class="channel-label">WhatsApp</span>
          <span class="channel-handle">+57 315 435 2572</span>
        </div>
        <span class="channel-arrow">→</span>
      </a>

      <a href={`mailto:${info.email}`} class="channel-card">
        <div class="channel-icon" style="color: var(--accent-yellow);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        </div>
        <div class="channel-info">
          <span class="channel-label">Email</span>
          <span class="channel-handle">{info.email}</span>
        </div>
        <span class="channel-arrow">→</span>
      </a>
    </div>

    <div class="contact-form-wrap">
      <h3 class="form-title">O envíame un mensaje directo</h3>
      <form class="contact-form" id="contact-form" action="https://formspree.io/f/xjgdkpaw" method="POST">
        <div class="form-row">
          <input type="text" name="name" placeholder="Tu nombre" required class="form-input" />
          <input type="email" name="email" placeholder="Tu email" required class="form-input" />
        </div>
        <input type="text" name="subject" placeholder="Asunto" class="form-input" />
        <textarea name="message" placeholder="Cuéntame sobre tu proyecto..." required class="form-input form-textarea" rows="4"></textarea>
        <button type="submit" class="btn btn-primary form-submit">
          Enviar mensaje
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-header { margin-bottom: 3rem; }
  .contact-header .section-label { margin: 0 auto 1rem; }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 3rem;
  }

  .channel-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    transition: all var(--transition-normal);
    text-align: left;
    text-decoration: none;
  }

  .channel-card:hover {
    border-color: var(--accent-yellow);
    box-shadow: 0 0 0 1px rgba(234, 179, 8, 0.1), var(--shadow-md);
    transform: translateX(4px);
  }

  .channel-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--text-secondary);
  }

  .channel-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .channel-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .channel-handle {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .channel-arrow {
    color: var(--text-tertiary);
    transition: all var(--transition-fast);
    font-size: 1.1rem;
  }

  .channel-card:hover .channel-arrow {
    color: var(--accent-yellow);
    transform: translateX(3px);
  }

  .channel-icon.wa { color: #25d366; }

  .contact-form-wrap {
    text-align: left;
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
  }

  .form-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }

  .form-input {
    width: 100%;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    transition: all var(--transition-fast);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--accent-yellow);
    box-shadow: 0 0 0 3px var(--accent-yellow-glow);
  }

  .form-input::placeholder {
    color: var(--text-tertiary);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-submit {
    align-self: flex-start;
    cursor: pointer;
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
