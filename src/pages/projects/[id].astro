---
import Layout from '../../layouts/Layout.astro'
import { projects } from '../../lib/projects'
import { info } from '../../lib/info'
import type { Project } from '../../types'

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { id: p.id },
    props: { project: p },
  }))
}

const { project } = Astro.props as { project: Project }

const pageTitle = `${project.name} · ${info.name}`
const pageDescription = `${project.name} — ${project.description}`
const pageImage = project.image || '/portfolio-full.png'
const pageUrl = `https://xenooxf.vercel.app/projects/${project.id}`
---

<Layout>
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={`https://xenooxf.vercel.app${pageImage}`} />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={`https://xenooxf.vercel.app${pageImage}`} />

  <nav class="project-nav">
    <div class="project-nav-inner">
      <a href="/" class="project-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Volver al portafolio
      </a>
      <span class="project-nav-brand">
        <span class="logo-bracket">&#123;</span>
        <span>junior</span>
        <span class="logo-bracket">&#125;</span>
      </span>
    </div>
  </nav>

  <article class="project-detail">
    <header class="pd-header">
      <div class="pd-meta">
        <span class={`badge badge-${project.maintenance === 'active' ? 'active' : project.maintenance === 'archived' ? 'archived' : 'stable'}`}>
          {project.maintenance === 'active' ? '▸ Activo' : project.maintenance === 'archived' ? '■ Archivado' : '● Estable'}
        </span>
        {!project.isMainTech && <span class="badge badge-explore">Explorando</span>}
        <span class="pd-year">{project.year}</span>
      </div>
      <h1 class="pd-title">{project.name}</h1>
      <p class="pd-subtitle">{project.description}</p>
    </header>

    {project.image && (
      <div class="pd-image-wrap">
        <img src={project.image} alt={project.name} class="pd-image" />
        <div class="pd-image-overlay">
          <div class="pd-tags">
            {project.tags.map((t) => <span class="pd-tag">{t}</span>)}
          </div>
        </div>
      </div>
    )}

    <div class="pd-content">
      <div class="pd-main">
        <h2>Acerca del proyecto</h2>
        <p>{project.longDescription}</p>

        {project.subProjects && project.subProjects.length > 0 && (
          <>
            <h3>Componentes</h3>
            <div class="pd-subs">
              {project.subProjects.map((sp) => (
                <a href={sp.url} target="_blank" rel="noopener" class="pd-sub-link">
                  <div>
                    <strong>{sp.name}</strong>
                    <span>{sp.tech}</span>
                  </div>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              ))}
            </div>
          </>
        )}
      </div>

      <aside class="pd-sidebar">
        <div class="pd-card">
          <h3>Tecnologías</h3>
          <div class="pd-tech-list">
            {project.tech.map((t) => <span class="pd-chip">{t}</span>)}
          </div>
        </div>

        <div class="pd-card">
          <h3>Enlaces</h3>
          <div class="pd-links">
            {project.demoUrl && (
              <a href={project.demoUrl} target="_blank" rel="noopener" class="pd-link pd-link-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                {project.category === 'fullstack' ? 'Frontend' : 'Demo'}
              </a>
            )}
            {project.backendUrl && (
              <a href={project.backendUrl} target="_blank" rel="noopener" class="pd-link pd-link-api">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                API
              </a>
            )}
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noopener" class="pd-link pd-link-gh">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                Código fuente
              </a>
            )}
          </div>
        </div>

        <div class="pd-card">
          <h3>Información</h3>
          <div class="pd-info-list">
            <div class="pd-info-item">
              <span class="pd-info-label">Categoría</span>
              <span class="pd-info-value">
                {project.category === 'fullstack' ? 'Full Stack' :
                 project.category === 'backend' ? 'Backend' :
                 project.category === 'frontend' ? 'Frontend' :
                 project.category === 'desktop' ? 'Desktop' : 'CLI'}
              </span>
            </div>
            <div class="pd-info-item">
              <span class="pd-info-label">Estado</span>
              <span class="pd-info-value" style={`color: ${project.maintenance === 'active' ? 'var(--accent-green)' : 'var(--text-tertiary)'}`}>
                {project.maintenance === 'active' ? 'Mantenimiento activo' :
                 project.maintenance === 'archived' ? 'Archivado' : 'Estable'}
              </span>
            </div>
            <div class="pd-info-item">
              <span class="pd-info-label">Año</span>
              <span class="pd-info-value">{project.year}</span>
            </div>
            {!project.isMainTech && (
              <div class="pd-info-item">
                <span class="pd-info-label">Stack</span>
                <span class="pd-info-value" style="color: var(--accent-amber);">Explorando</span>
              </div>
            )}
          </div>
        </div>
      </aside>
    </div>

    <div class="pd-footer">
      <a href="/" class="btn btn-primary">← Volver al portafolio</a>
      <a href="/#contact" class="btn btn-outline">¿Interesado? Contáctame</a>
    </div>
  </article>

  <style>
    .project-nav {
      padding: 1rem 2rem;
      border-bottom: 1px solid var(--border-color);
      background: var(--bg-nav);
      backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .project-nav-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .project-back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      transition: color var(--transition-fast);
    }

    .project-back:hover { color: var(--text-primary); }

    .project-nav-brand {
      font-weight: 700;
      font-size: 0.95rem;
    }

    .logo-bracket { color: var(--accent-yellow); font-weight: 400; }

    .project-detail {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
    }

    .pd-header {
      margin-bottom: 2.5rem;
    }

    .pd-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .badge {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.2rem 0.65rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    .badge-active {
      background: rgba(5, 150, 105, 0.08);
      color: var(--accent-green);
      border: 1px solid rgba(5, 150, 105, 0.15);
    }

    .badge-archived {
      background: rgba(100, 116, 139, 0.08);
      color: var(--text-tertiary);
      border: 1px solid rgba(100, 116, 139, 0.15);
    }

    .badge-stable {
      background: rgba(37, 99, 235, 0.08);
      color: var(--accent-blue);
      border: 1px solid rgba(37, 99, 235, 0.15);
    }

    .badge-explore {
      background: rgba(124, 58, 237, 0.08);
      color: var(--accent-purple);
      border: 1px solid rgba(124, 58, 237, 0.15);
    }

    .pd-year {
      font-size: 0.85rem;
      color: var(--text-tertiary);
      font-weight: 600;
    }

    .pd-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin-bottom: 0.6rem;
    }

    .pd-subtitle {
      font-size: 1.1rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .pd-image-wrap {
      position: relative;
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 3rem;
      border: 1px solid var(--border-color);
    }

    .pd-image {
      width: 100%;
      height: 400px;
      object-fit: cover;
      object-position: top;
      display: block;
    }

    .pd-image-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem;
      background: linear-gradient(transparent, rgba(0,0,0,0.6));
    }

    .pd-tags {
      display: flex;
      gap: 0.4rem;
    }

    .pd-tag {
      font-size: 0.75rem;
      padding: 0.25rem 0.7rem;
      border-radius: 100px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(8px);
      color: white;
      font-weight: 500;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .pd-content {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 3rem;
      align-items: start;
    }

    .pd-main h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .pd-main h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin: 1.5rem 0 0.8rem;
      color: var(--text-primary);
    }

    .pd-main p {
      font-size: 1rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .pd-subs {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .pd-sub-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.8rem 1rem;
      border-radius: var(--radius-sm);
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      text-decoration: none;
      color: var(--text-primary);
      transition: all var(--transition-fast);
    }

    .pd-sub-link:hover {
      border-color: var(--accent-yellow);
      background: var(--accent-yellow-glow);
    }

    .pd-sub-link strong {
      display: block;
      font-size: 0.88rem;
      margin-bottom: 0.1rem;
    }

    .pd-sub-link span:not(strong) {
      font-size: 0.78rem;
      color: var(--text-tertiary);
    }

    .pd-sub-link svg {
      color: var(--text-tertiary);
      flex-shrink: 0;
    }

    .pd-card {
      padding: 1.5rem;
      border-radius: var(--radius-md);
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      margin-bottom: 1rem;
    }

    .pd-card h3 {
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: var(--text-primary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .pd-tech-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .pd-chip {
      font-size: 0.72rem;
      padding: 0.25rem 0.6rem;
      border-radius: 100px;
      background: rgba(37, 99, 235, 0.06);
      border: 1px solid rgba(37, 99, 235, 0.1);
      color: var(--accent-blue);
      font-weight: 500;
    }

    .pd-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .pd-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 0.8rem;
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: all var(--transition-fast);
    }

    .pd-link-primary {
      background: var(--accent-blue);
      color: white;
    }
    .pd-link-primary:hover { background: var(--accent-blue-dark); }

    .pd-link-api {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }
    .pd-link-api:hover { background: var(--border-color); }

    .pd-link-gh {
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
    }
    .pd-link-gh:hover { border-color: var(--text-primary); color: var(--text-primary); }

    .pd-info-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .pd-info-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .pd-info-label {
      font-size: 0.8rem;
      color: var(--text-tertiary);
    }

    .pd-info-value {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .pd-footer {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    @media (max-width: 900px) {
      .pd-content {
        grid-template-columns: 1fr;
      }
      .pd-image { height: 250px; }
      .project-detail { padding: 2rem 1.25rem 3rem; }
    }
  </style>
</Layout>
